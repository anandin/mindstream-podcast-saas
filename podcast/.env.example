# === API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs - get from elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice IDs for the two hosts
# Find voice IDs at elevenlabs.io/app/voice-lab or use defaults below
# Default: "Rachel" (analytical host) and "Adam" (storytelling host)
ELEVENLABS_VOICE_HOST_1=21m00Tcm4TlvDq8ikWAM   # Rachel - calm, analytical
ELEVENLABS_VOICE_HOST_2=pNInz6obpgDQGcFmaJgB   # Adam  - warm, storytelling

# ElevenLabs model (eleven_multilingual_v2 recommended for quality)
ELEVENLABS_MODEL=eleven_multilingual_v2

# Transistor.fm - get from transistor.fm/account/api-key
TRANSISTOR_API_KEY=your_transistorfm_api_key_here
TRANSISTOR_SHOW_ID=your_transistorfm_show_id_here

# NewsAPI - get from newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# === Podcast Config ===
PODCAST_TITLE_PREFIX=Mind the Gap
HOST_1_NAME=Alex
HOST_2_NAME=Maya
SHOW_LANGUAGE=en
# Episode duration target (in words — ~150 words/min for podcast speech)
TARGET_WORD_COUNT=1500

# Voxtral (Mistral) - get from console.mistral.ai
VOXTRAL_API_KEY=your_voxtral_api_key_here

# MiniMax - get from platform.minimax.chat
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
